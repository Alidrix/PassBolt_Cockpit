IMPORTER_API_PORT=9090
IMPORTER_UI_PORT=9091
PASSBOLT_CONTAINER=passbolt-passbolt-1
PASSBOLT_CLI_PATH=/usr/share/php/passbolt/bin/cake
IMPORT_COMMAND_TIMEOUT=60
IMPORT_TOTAL_TIMEOUT=60
PASSBOLT_URL=https://passbolt.example.com
PASSBOLT_VERIFY_TLS=true
PASSBOLT_API_BASE_URL=https://passbolt.example.com
PASSBOLT_API_AUTH_MODE=jwt
PASSBOLT_API_USER_ID=
PASSBOLT_API_PRIVATE_KEY_PATH=/app/keys/admin-private.asc
PASSBOLT_API_PASSPHRASE=
PASSBOLT_API_VERIFY_TLS=true
PASSBOLT_API_CA_BUNDLE=
PASSBOLT_API_MFA_PROVIDER=totp
PASSBOLT_API_TOTP_SECRET=
PASSBOLT_API_TIMEOUT=30
PASSBOLT_API_DEBUG=false
